<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.RowConstraints?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.javafx.onlinelearningsystem.controller.admin.EditCourseController"
      spacing="20.0" styleClass="card" stylesheets="@../../styles.css"
      prefWidth="500.0" prefHeight="520.0">

    <padding>
        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
    </padding>

    <VBox spacing="8.0">
        <Label text="Edit Course" styleClass="pageTitle-label"/>
        <Label text="Edit course information" styleClass="stat-label"/>
    </VBox>

    <Separator/>

    <GridPane hgap="15.0" vgap="18.0" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" prefWidth="120.0"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Title:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="titleField" promptText="Enter title" styleClass="login-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>

        <Label text="Description:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="descriptionField" promptText="Enter description" styleClass="login-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>

        <Label styleClass="login-label" text="ECTS:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Spinner fx:id="ectsSpinner" editable="true" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.hgrow="ALWAYS" maxWidth="Infinity">
        </Spinner>

        <Label text="Teacher:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="teacherComboBox" promptText="Select a teacher"
                  prefHeight="150.0" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.hgrow="ALWAYS" maxWidth="Infinity"/>


        <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
        </rowConstraints>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <Separator/>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button fx:id="closeButton" text="Cancel" onAction="#handleClose" styleClass="secondary-button" prefWidth="100.0"/>
        <Button text="Save Course" onAction="#handleSave" styleClass="primary-button" prefWidth="130.0" defaultButton="true"/>
    </HBox>
</VBox>