<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.javafx.onlinelearningsystem.controller.admin.AdminCoursesController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
      </padding>

      <Label styleClass="pageTitle-label" text="Course Management"/>

      <HBox maxWidth="1.7976931348623157E308" prefHeight="160.0" spacing="15.0">
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalCoursesLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Courses"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalEnrollmentsLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Enrollments"/>
         </VBox>
      </HBox>


      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <Button fx:id="addCourseButton" onAction="#handleAddCourse" styleClass="primary-button" text="Add Course"/>
         <Button fx:id="editCourseButton" onAction="#handleEditCourse" styleClass="secondary-button" text="Edit Course"/>
         <Button onAction="#handleRemoveCourse" styleClass="danger-button" text="Delete Course"/>
         <Button onAction="#handleManageStudents" styleClass="secondary-button" text="Manage Students"/>
      </HBox>
      <Label styleClass="section-label" text="All Courses"/>
      <TableView fx:id="coursesTable" maxWidth="1.7976931348623157E308"
                 prefHeight="500.0" VBox.vgrow="ALWAYS">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="courseIdColumn" prefWidth="60.0" text="ID"/>
            <TableColumn fx:id="courseNameColumn" prefWidth="100.0" text="Course Name"/>
            <TableColumn fx:id="courseDescriptionColumn" prefWidth="250.0" text="Description"/>
            <TableColumn fx:id="courseECTSColumn" prefWidth="60.0" text="ECTS"/>
            <TableColumn fx:id="teacherColumn" prefWidth="150.0" text="Assigned Teacher"/>
            <TableColumn fx:id="studentsCountColumn" prefWidth="60.0" text="Students"/>
            <TableColumn fx:id="lessonsCountColumn" prefWidth="60.0" text="Lessons"/>
            <TableColumn fx:id="quizzesCountColumn" prefWidth="60.0" text="Quizzes"/>
         </columns>
      </TableView>
   </VBox>
</AnchorPane>
