<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.javafx.onlinelearningsystem.controller.admin.AdminOverviewController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
      </padding>
      <Label styleClass="pageTitle-label" text="System Overview"/>
      <HBox maxWidth="1.7976931348623157E308" prefHeight="160.0" spacing="15.0">
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalStudentsLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Students"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalTeachersLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Teachers"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalCoursesLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Active Courses"/>
         </VBox>
      </HBox>
      <Label styleClass="section-label" text="Recent User Activity"/>
      <TableView fx:id="userActivityTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="userNameColumn" prefWidth="120.0" text="User Name"/>
            <TableColumn fx:id="roleColumn" prefWidth="80.0" text="Role"/>
            <TableColumn fx:id="activityColumn" prefWidth="150.0" text="Activity"/>
            <TableColumn fx:id="activityDateColumn" prefWidth="100.0" text="Date &amp; Time"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="Recent Course Enrollments"/>
      <TableView fx:id="enrolmentsTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="studentColumn" prefWidth="120.0" text="Student Name"/>
            <TableColumn fx:id="courseColumn" prefWidth="120.0" text="Course Name"/>
            <TableColumn fx:id="teacherColumn" prefWidth="100.0" text="Teacher"/>
            <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Enrollment Date"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="Recent Authentication Failures"/>
      <TableView fx:id="auditEventsTable" maxWidth="1.7976931348623157E308" minHeight="130.0" prefHeight="170.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="auditTimestampColumn" prefWidth="150.0" text="Timestamp"/>
            <TableColumn fx:id="auditUsernameColumn" prefWidth="120.0" text="Username"/>
            <TableColumn fx:id="auditReasonColumn" prefWidth="140.0" text="Reason"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="System Statistics"/>
      <HBox maxWidth="1.7976931348623157E308" prefHeight="140.0" spacing="15.0">
         <VBox maxWidth="1.7976931348623157E308" prefHeight="140.0"
               spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <padding>
               <Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/>
            </padding>
            <Label styleClass="stat-label" text="Total Quizzes"/>
            <Label fx:id="totalQuizzesLabel" styleClass="stat-value"/>
         </VBox>
         <VBox maxWidth="1.7976931348623157E308" prefHeight="140.0"
               spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <padding>
               <Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/>
            </padding>
            <Label styleClass="stat-label" text="Total Lessons"/>
            <Label fx:id="totalLessonsLabel" styleClass="stat-value" />
         </VBox>
         <VBox maxWidth="1.7976931348623157E308" prefHeight="140.0"
               spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
            <padding>
               <Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/>
            </padding>
            <Label styleClass="stat-label" text="Total Enrollments"/>
            <Label fx:id="totalEnrollmentsLabel" styleClass="stat-value"/>
         </VBox>
      </HBox>
   </VBox>
</AnchorPane>
