<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.javafx.onlinelearningsystem.controller.student.StudentOverviewController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
      </padding>
      <Label styleClass="pageTitle-label" text="Overview"/>
      <HBox maxWidth="1.7976931348623157E308" prefHeight="160.0" spacing="15.0">
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalCoursesLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Active Courses"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalActiveEctsLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Active ECTS"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalAcquiredEctsLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Acquired ECTS"/>
         </VBox>
      </HBox>
      <Label styleClass="section-label" text="Active Courses"/>
      <TableView fx:id="activeCoursesTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="titleColumn" prefWidth="150.0" text="Title"/>
            <TableColumn fx:id="teacherColumn" prefWidth="100.0" text="Teacher"/>
            <TableColumn fx:id="ectsColumn" prefWidth="100.0" text="ECTS"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="Pending Tests"/>
      <TableView fx:id="pendingTestsTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="pendingTitleColumn" prefWidth="150.0" text="Title"/>
            <TableColumn fx:id="pendingClassColumn" prefWidth="100.0" text="Class"/>
            <TableColumn fx:id="pendingDueDateColumn" prefWidth="100.0" text="Due Date"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="Completed Tests"/>
      <TableView fx:id="completedTestsTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="completedTitleColumn" prefWidth="75.0" text="Title"/>
            <TableColumn fx:id="completedClassColumn" prefWidth="75.0" text="Class"/>
            <TableColumn fx:id="completedSubmitDateColumn" prefWidth="75.0" text="Submit Date"/>
            <TableColumn fx:id="completedGradeColumn" prefWidth="75.0" text="Grade"/>
         </columns>
      </TableView>
   </VBox>
</AnchorPane>