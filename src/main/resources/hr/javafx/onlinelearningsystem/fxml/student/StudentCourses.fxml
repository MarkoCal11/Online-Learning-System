<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.javafx.onlinelearningsystem.controller.student.StudentCoursesController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
      </padding>

      <Label styleClass="pageTitle-label" text="My Courses"/>

      <VBox fx:id="coursesContainer" spacing="20.0">
         <padding>
            <Insets bottom="10.0" right="10.0"/>
         </padding>
      </VBox>
   </VBox>
</AnchorPane>