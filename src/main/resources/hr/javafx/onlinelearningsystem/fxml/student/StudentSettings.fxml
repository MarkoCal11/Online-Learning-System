<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.javafx.onlinelearningsystem.controller.student.StudentSettingsController">
   <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0" />
      </padding>
      <Label styleClass="pageTitle-label" text="Settings" />
      <VBox spacing="12.0" styleClass="card">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <Label styleClass="section-label" text="Password Change" />
         <Label text="Send a password change request to the admin. You will receive access after approval." wrapText="true" />
         <Label fx:id="requestStatusLabel" styleClass="stat-label" text="Request status: No pending requests" />
         <Button fx:id="requestButton" mnemonicParsing="false" onAction="#handleRequestPasswordChange" styleClass="primary-button" text="Request Password Change" />
      </VBox>
   </VBox>
</AnchorPane>

