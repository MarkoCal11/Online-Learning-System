<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.javafx.onlinelearningsystem.controller.teacher.ManageQuestionsController"
      spacing="16.0" styleClass="card" stylesheets="@../../styles.css"
      prefWidth="890.0" prefHeight="600.0">

    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="6.0">
        <Label text="Manage Questions" styleClass="pageTitle-label"/>
        <Label text="Create, edit and remove quiz questions" styleClass="stat-label"/>
    </VBox>

    <Separator/>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Existing Questions" styleClass="subsection-label" HBox.hgrow="ALWAYS"/>
                <Button fx:id="newButton" text="+ New" onAction="#handleNew" styleClass="secondary-button"/>
            </HBox>
            <ListView fx:id="questionsList" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="12.0" HBox.hgrow="ALWAYS">
            <Label text="Question Form" styleClass="subsection-label"/>

            <GridPane hgap="12.0" vgap="12.0" VBox.vgrow="ALWAYS">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="120.0"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Question:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextArea fx:id="questionTextArea" promptText="Enter question text"
                          styleClass="text-area"
                          prefRowCount="3"
                          GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Option A:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="optionAField" promptText="First option" styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Option B:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="optionBField" promptText="Second option" styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Option C:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="optionCField" promptText="Third option" styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Option D:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="optionDField" promptText="Fourth option" styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Correct:" styleClass="login-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <ComboBox fx:id="correctAnswerCombo" styleClass="login-field"
                          GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            </GridPane>

            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete" styleClass="danger-button"/>
                <Button fx:id="saveButton" text="Save Question" onAction="#handleSave" styleClass="primary-button"/>
            </HBox>
        </VBox>
    </HBox>

    <Separator/>

    <HBox spacing="12.0" alignment="CENTER_RIGHT">
        <Button fx:id="closeButton" text="Close" onAction="#handleClose" styleClass="secondary-button" prefWidth="100.0"/>
    </HBox>
</VBox>

