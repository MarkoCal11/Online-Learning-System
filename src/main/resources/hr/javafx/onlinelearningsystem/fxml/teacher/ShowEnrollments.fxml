<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="560.0" prefWidth="812.0" spacing="16.0" styleClass="card" stylesheets="@../../styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.javafx.onlinelearningsystem.controller.teacher.ShowEnrollmentsController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label fx:id="courseTitleLabel" styleClass="course-title" />

    <Separator />

    <VBox spacing="8.0">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label styleClass="subsection-label" text="Enrolled Students" HBox.hgrow="ALWAYS" />
        </HBox>

        <TableView fx:id="enrolledStudentsList" prefHeight="320.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameColumn" prefWidth="220.0" text="Full Name" />
                <TableColumn fx:id="usernameColumn" prefWidth="150.0" text="Username" />
                <TableColumn fx:id="jmbagColumn" prefWidth="140.0" text="JMBAG" />
                <TableColumn fx:id="statusColumn" prefWidth="110.0" text="Status" />
                <TableColumn fx:id="finalGradeColumn" prefWidth="130.0" text="Final Grade" />
            </columns>
        </TableView>
    </VBox>

    <HBox spacing="10.0">
        <HBox HBox.hgrow="ALWAYS" />
        <Button onAction="#handleSetGrade" styleClass="primary-button" text="Set/Edit Final Grade" />
        <Button fx:id="closeButton" onAction="#handleClose" styleClass="secondary-button" text="Close" />
    </HBox>

</VBox>