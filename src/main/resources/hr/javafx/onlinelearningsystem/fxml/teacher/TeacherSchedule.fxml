<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hr.javafx.onlinelearningsystem.controller.teacher.TeacherScheduleController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0" />
      </padding>
      <Label styleClass="pageTitle-label" text="Schedule" />

      <HBox alignment="CENTER" spacing="15.0">
         <Button mnemonicParsing="false" onAction="#handlePreviousWeek" styleClass="secondary-button" text="Previous Week" />
         <Button mnemonicParsing="false" onAction="#handleToday" styleClass="secondary-button" text="Today" />
         <Button mnemonicParsing="false" onAction="#handleNextWeek" styleClass="secondary-button" text="Next Week" />
      </HBox>

      <HBox alignment="CENTER" spacing="10.0">
         <Label styleClass="stat-label" text="Week of:" />
         <Label fx:id="weekRangeLabel" styleClass="stat-value" text="-" />
      </HBox>

      <Label styleClass="section-label" text="This Week's Scheduled Quizzes" />
      <VBox fx:id="scheduleContent" spacing="15.0" VBox.vgrow="ALWAYS" />
   </VBox>
</AnchorPane>
