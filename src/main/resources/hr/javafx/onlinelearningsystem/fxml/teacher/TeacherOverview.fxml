<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>

<AnchorPane minHeight="0.0" minWidth="0.0" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="hr.javafx.onlinelearningsystem.controller.teacher.TeacherOverviewController">
   <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="30.0" left="25.0" right="25.0" top="30.0"/>
      </padding>
      <Label styleClass="pageTitle-label" text="Overview"/>
      <HBox maxWidth="1.7976931348623157E308" prefHeight="160.0" spacing="15.0">
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalCoursesLabel" styleClass="stat-value" />
            <Label styleClass="stat-label" text="Courses Teaching"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="totalStudentsLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Total Students"/>
         </VBox>
         <VBox alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="160.0"
               spacing="10.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label fx:id="upcomingQuizzesLabel" styleClass="stat-value"/>
            <Label styleClass="stat-label" text="Upcoming quizzes"/>
         </VBox>
      </HBox>
      <Label styleClass="section-label" text="Upcoming Quizzes"/>
      <TableView fx:id="upcomingQuizzesTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="upcomingQuizTitleColumn" prefWidth="150.0" text="Quiz Title"/>
            <TableColumn fx:id="upcomingQuizCourseColumn" prefWidth="100.0" text="Course"/>
            <TableColumn fx:id="upcomingQuizDueDateColumn" prefWidth="100.0" text="Due Date"/>
            <TableColumn fx:id="upcomingQuizActionColumn" prefWidth="75.0" text="Status"/>
         </columns>
      </TableView>
      <Label styleClass="section-label" text="Recent Student Submissions"/>
      <TableView fx:id="recentSubmissionsTable" maxWidth="1.7976931348623157E308" minHeight="150.0" prefHeight="200.0" VBox.vgrow="SOMETIMES">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="recentSubmissionStudentColumn" prefWidth="100.0" text="Student Name"/>
            <TableColumn fx:id="recentSubmissionQuizColumn" prefWidth="100.0" text="Quiz Title"/>
            <TableColumn fx:id="recentSubmissionCourseColumn" prefWidth="75.0" text="Course"/>
            <TableColumn fx:id="recentSubmissionGradeColumn" prefWidth="75.0" text="Grade"/>
            <TableColumn fx:id="recentSubmissionDateColumn" prefWidth="75.0" text="Submit Date"/>
         </columns>
      </TableView>
   </VBox>
</AnchorPane>

